---
import { Image } from "astro:assets";
import banner from "../assets/banner.png";
import {
  getLatestRelease,
  LATEST_RELEASE_URL,
} from "../lib/releases";

const latest = await getLatestRelease();
const latestTag = latest?.tag_name ?? "v0.4.8";
const downloadUrl = latest?.html_url ?? LATEST_RELEASE_URL;
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10 opacity-70"
    style="background: radial-gradient(60% 50% at 50% 10%, rgba(110,192,255,0.35), transparent 65%), radial-gradient(40% 40% at 80% 30%, rgba(255,200,61,0.18), transparent 70%);"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 pt-16 pb-20 sm:pt-24 sm:pb-28 text-center">
    <p
      class="chip-pixel mb-6 bg-[color:var(--color-sky)] text-[color:var(--color-ink)]"
      style="font-family: var(--font-display);"
    >
      ◆ pygame-ce build · {latestTag}
    </p>

    <Image
      src={banner}
      alt="Skyward Race"
      widths={[480, 768, 1024, 1280]}
      sizes="(max-width: 640px) 90vw, 640px"
      class="pixelated mx-auto w-full max-w-[640px] h-auto drop-shadow-[0_8px_0_rgba(10,15,36,0.6)]"
      loading="eager"
    />

    <h1 class="sr-only">Skyward Race</h1>

    <p
      class="mt-8 text-base sm:text-lg text-[color:var(--color-sky-light)] max-w-xl mx-auto leading-relaxed"
      style="font-family: var(--font-body);"
    >
      A 2D pixel-art arcade racer. Climb, compete, claim the crown.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href={downloadUrl} target="_blank" rel="noopener" class="btn-pixel btn-primary">
        ▼ Download {latestTag}
      </a>
      <a href="#features" class="btn-pixel btn-secondary">
        ▶ See features
      </a>
    </div>

    <p
      class="mt-8 text-[10px] uppercase tracking-[0.25em] text-[color:var(--color-muted)]"
      style="font-family: var(--font-display);"
    >
      Windows .exe · standalone · no install
    </p>
  </div>
</section>
