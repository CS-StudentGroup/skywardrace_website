---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const items = (await getCollection("roadmap")).sort((a, b) => {
  const statusOrder: Record<string, number> = {
    "in-progress": 0,
    planned: 1,
    done: 2,
  };
  const s = statusOrder[a.data.status] - statusOrder[b.data.status];
  return s !== 0 ? s : a.data.order - b.data.order;
});

const devlogEntries = await getCollection("devlog");
const entryCountByRoadmap = new Map<string, number>();
for (const entry of devlogEntries) {
  const id = entry.data.roadmap.id;
  entryCountByRoadmap.set(id, (entryCountByRoadmap.get(id) ?? 0) + 1);
}

const statusStyles: Record<string, string> = {
  planned: "bg-[color:var(--color-muted)] text-[color:var(--color-ink)]",
  "in-progress": "bg-[color:var(--color-gold)] text-[color:var(--color-ink)]",
  done: "bg-[color:var(--color-sky)] text-[color:var(--color-ink)]",
};
---

<Layout
  title="Roadmap · Skyward Race"
  description="Long-term goals for Skyward Race and the progress getting there."
>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-12">
    <p
      class="chip-pixel bg-[color:var(--color-sky)] text-[color:var(--color-ink)] mb-4"
      style="font-family: var(--font-display);"
    >
      ✦ Roadmap
    </p>
    <h1 class="heading-pixel text-4xl sm:text-5xl">The journey</h1>
    <p
      class="mt-4 text-[color:var(--color-sky-light)] text-sm sm:text-base max-w-2xl"
      style="font-family: var(--font-body);"
    >
      Every big plan for Skyward Race &mdash; the why, the status, and a stream
      of devlogs documenting how we got there.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-8 pb-24">
    <ol class="space-y-5">
      {
        items.map((item) => {
          const count = entryCountByRoadmap.get(item.id) ?? 0;
          return (
            <li>
              <a
                href={`/roadmap/${item.id}`}
                class="panel-pixel p-6 block hover:-translate-y-0.5 transition-transform"
              >
                <div class="flex flex-wrap items-center gap-3 mb-3">
                  <span
                    class={`chip-pixel ${statusStyles[item.data.status]}`}
                    style="font-family: var(--font-display);"
                  >
                    {item.data.status}
                  </span>
                  {item.data.target && (
                    <span
                      class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-muted)]"
                      style="font-family: var(--font-display);"
                    >
                      target {item.data.target}
                    </span>
                  )}
                  <span
                    class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-muted)] ml-auto"
                    style="font-family: var(--font-display);"
                  >
                    {count} {count === 1 ? "entry" : "entries"}
                  </span>
                </div>
                <h2
                  class="text-xl sm:text-2xl font-black uppercase tracking-wide text-[color:var(--color-gold)]"
                  style="font-family: var(--font-display); text-shadow: 2px 2px 0 var(--color-ink);"
                >
                  {item.data.title}
                </h2>
                <p
                  class="mt-3 text-[color:var(--color-sky-light)] text-sm leading-relaxed"
                  style="font-family: var(--font-body);"
                >
                  {item.data.summary}
                </p>
                <p
                  class="mt-4 text-[10px] uppercase tracking-[0.25em] text-[color:var(--color-sky)]"
                  style="font-family: var(--font-display);"
                >
                  Open →
                </p>
              </a>
            </li>
          );
        })
      }
    </ol>
  </section>
</Layout>
