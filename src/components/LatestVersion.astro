---
import { getLatestRelease, LATEST_RELEASE_URL, formatBytes } from "../lib/releases";
import { getMilestoneNote } from "../data/milestone-versions";

const latest = await getLatestRelease();
const tag = latest?.tag_name ?? "v0.4.8";
const url = latest?.html_url ?? LATEST_RELEASE_URL;
const milestoneNote = getMilestoneNote(tag);
const primaryAsset = latest?.assets[0];
const date = latest
  ? new Date(latest.published_at).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<section id="latest-version" class="max-w-6xl mx-auto px-6 py-20">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p
        class="chip-pixel bg-[color:var(--color-gold)] text-[color:var(--color-ink)] mb-4"
        style="font-family: var(--font-display);"
      >
        ◇ Current build
      </p>
      <h2 class="heading-pixel text-3xl sm:text-4xl">Latest version</h2>
      <p
        class="mt-3 text-[color:var(--color-sky-light)] text-sm sm:text-base max-w-xl"
        style="font-family: var(--font-body);"
      >
        Grab the most recent playable build straight from GitHub releases.
      </p>
    </div>
    <a href="/versions" class="btn-pixel btn-secondary text-xs">
      ▶ All versions
    </a>
  </div>

  <div class="panel-pixel p-6 sm:p-8">
    <div class="grid sm:grid-cols-[1fr_auto] gap-6 items-center">
      <div>
        <div class="flex flex-wrap items-center gap-3 mb-3">
          <span
            class="chip-pixel bg-[color:var(--color-gold)] text-[color:var(--color-ink)]"
            style="font-family: var(--font-display);"
          >
            {tag}
          </span>
          <span
            class="chip-pixel bg-[color:var(--color-sky)] text-[color:var(--color-ink)]"
            style="font-family: var(--font-display);"
          >
            Latest
          </span>
          {milestoneNote && (
            <span
              class="chip-pixel bg-[color:var(--color-crown)] text-[color:var(--color-ink)]"
              style="font-family: var(--font-display);"
            >
              ★ Milestone
            </span>
          )}
          {date && (
            <span
              class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-muted)]"
              style="font-family: var(--font-display);"
            >
              {date}
            </span>
          )}
        </div>
        {latest?.name && (
          <h3
            class="font-bold text-base sm:text-lg uppercase tracking-wide text-[color:var(--color-sky)]"
            style="font-family: var(--font-display);"
          >
            {latest.name}
          </h3>
        )}
        <p
          class="mt-2 text-[color:var(--color-sky-light)] text-sm sm:text-base"
          style="font-family: var(--font-body);"
        >
          {milestoneNote ?? "Windows .exe, standalone, no install."}
        </p>
      </div>

      <div class="flex flex-col sm:items-end gap-2">
        <a
          href={primaryAsset?.browser_download_url ?? url}
          class="btn-pixel btn-primary"
        >
          ▼ Download {tag}
        </a>
        {primaryAsset && (
          <span
            class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-muted)]"
            style="font-family: var(--font-display);"
          >
            {primaryAsset.name} · {formatBytes(primaryAsset.size)}
          </span>
        )}
      </div>
    </div>
  </div>
</section>
