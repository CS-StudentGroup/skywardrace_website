---
import { getCollection } from "astro:content";

const all = await getCollection("roadmap");
const featured = all
  .filter((r) => r.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const statusStyles: Record<string, string> = {
  planned: "bg-[color:var(--color-muted)] text-[color:var(--color-ink)]",
  "in-progress": "bg-[color:var(--color-gold)] text-[color:var(--color-ink)]",
  done: "bg-[color:var(--color-sky)] text-[color:var(--color-ink)]",
};
---

<section id="roadmap-teaser" class="max-w-6xl mx-auto px-6 py-20">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p
        class="chip-pixel bg-[color:var(--color-sky)] text-[color:var(--color-ink)] mb-4"
        style="font-family: var(--font-display);"
      >
        ✦ Roadmap
      </p>
      <h2 class="heading-pixel text-3xl sm:text-4xl">What's next</h2>
      <p
        class="mt-3 text-[color:var(--color-sky-light)] text-sm sm:text-base max-w-xl"
        style="font-family: var(--font-body);"
      >
        Long-term goals for the game and the progress getting there.
      </p>
    </div>
    <a href="/roadmap" class="btn-pixel btn-secondary text-xs">
      ▶ Full roadmap
    </a>
  </div>

  <div class="grid sm:grid-cols-2 gap-5">
    {
      featured.map((r) => (
        <a
          href={`/roadmap/${r.id}`}
          class="panel-pixel p-6 block hover:-translate-y-0.5 transition-transform"
        >
          <div class="flex items-center gap-3 flex-wrap mb-3">
            <span
              class={`chip-pixel ${statusStyles[r.data.status]}`}
              style="font-family: var(--font-display);"
            >
              {r.data.status}
            </span>
            {r.data.target && (
              <span
                class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-muted)]"
                style="font-family: var(--font-display);"
              >
                target {r.data.target}
              </span>
            )}
          </div>
          <h3
            class="text-xl sm:text-2xl font-black uppercase tracking-wide text-[color:var(--color-gold)]"
            style="font-family: var(--font-display); text-shadow: 2px 2px 0 var(--color-ink);"
          >
            {r.data.title}
          </h3>
          <p
            class="mt-3 text-[color:var(--color-sky-light)] text-sm leading-relaxed"
            style="font-family: var(--font-body);"
          >
            {r.data.summary}
          </p>
          <p
            class="mt-4 text-[10px] uppercase tracking-[0.25em] text-[color:var(--color-sky)]"
            style="font-family: var(--font-display);"
          >
            Read more →
          </p>
        </a>
      ))
    }
  </div>
</section>
