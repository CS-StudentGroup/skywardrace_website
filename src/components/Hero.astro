---
const releaseUrl =
  "https://github.com/Andott1/pdc_final_project/releases/latest";
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10 opacity-60"
    style="background: radial-gradient(60% 50% at 50% 0%, rgba(255,179,71,0.25), transparent 70%), radial-gradient(40% 40% at 80% 20%, rgba(110,168,255,0.18), transparent 70%);"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 pt-24 pb-20 sm:pt-32 sm:pb-28 text-center">
    <p
      class="inline-block text-xs uppercase tracking-[0.2em] text-[color:var(--color-accent)] border border-[color:var(--color-accent)]/30 rounded-full px-3 py-1 mb-6"
    >
      pygame-ce build · v1
    </p>
    <h1
      class="font-[family-name:var(--font-display)] text-5xl sm:text-7xl font-bold tracking-tight"
    >
      Skyward Race
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-[color:var(--color-muted)] max-w-2xl mx-auto">
      A fast, parallel-and-distributed arcade racer built in pygame-ce.
      Compete, spectate, climb.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href={releaseUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 bg-[color:var(--color-accent)] text-black font-semibold px-6 py-3 rounded-lg hover:brightness-110 transition"
      >
        Download latest release
        <span aria-hidden>↗</span>
      </a>
      <a
        href="#about"
        class="inline-flex items-center gap-2 border border-white/10 px-6 py-3 rounded-lg text-[color:var(--color-fg)] hover:bg-white/5 transition"
      >
        Learn more
      </a>
    </div>

    <p class="mt-6 text-xs text-[color:var(--color-muted)]">
      Windows executable · standalone build · no install required
    </p>
  </div>
</section>
