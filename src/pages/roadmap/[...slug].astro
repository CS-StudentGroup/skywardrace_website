---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("roadmap");
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const allDevlog = await getCollection("devlog");
const entries = allDevlog
  .filter((e) => e.data.roadmap.id === item.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const renderedEntries = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

const statusStyles: Record<string, string> = {
  planned: "bg-[color:var(--color-muted)] text-[color:var(--color-ink)]",
  "in-progress": "bg-[color:var(--color-gold)] text-[color:var(--color-ink)]",
  done: "bg-[color:var(--color-sky)] text-[color:var(--color-ink)]",
};

const startedDisplay = item.data.startedAt
  ? item.data.startedAt.toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<Layout
  title={`${item.data.title} · Skyward Race`}
  description={item.data.summary}
>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-12">
    <div class="max-w-4xl">
      <a
        href="/roadmap"
        class="text-[10px] uppercase tracking-[0.25em] text-[color:var(--color-muted)] hover:text-[color:var(--color-sky)]"
        style="font-family: var(--font-display);"
      >
        ← Back to roadmap
      </a>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span
          class={`chip-pixel ${statusStyles[item.data.status]}`}
          style="font-family: var(--font-display);"
        >
          {item.data.status}
        </span>
        {
          item.data.target && (
            <span
              class="chip-pixel bg-[color:var(--color-sky)] text-[color:var(--color-ink)]"
              style="font-family: var(--font-display);"
            >
              target {item.data.target}
            </span>
          )
        }
        {
          startedDisplay && (
            <span
              class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-muted)]"
              style="font-family: var(--font-display);"
            >
              started {startedDisplay}
            </span>
          )
        }
      </div>

      <h1 class="heading-pixel text-4xl sm:text-5xl mt-4">
        {item.data.title}
      </h1>
      <p
        class="mt-4 text-[color:var(--color-sky-light)] text-base sm:text-lg leading-relaxed"
        style="font-family: var(--font-body);"
      >
        {item.data.summary}
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-8">
    <div class="max-w-4xl">
      <div class="panel-pixel p-6 sm:p-8">
        <div
          class="text-[color:var(--color-fg)]/90 leading-relaxed space-y-4 text-sm sm:text-base"
          style="font-family: var(--font-body);"
        >
          <Content />
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-8 pb-24">
    <div class="max-w-4xl">
      <h2 class="heading-pixel text-2xl sm:text-3xl mb-2">Devlog</h2>
      <p
        class="text-[color:var(--color-sky-light)] text-sm mb-8"
        style="font-family: var(--font-body);"
      >
        {renderedEntries.length} {renderedEntries.length === 1 ? "entry" : "entries"},
        newest first.
      </p>

      {
        renderedEntries.length === 0 ? (
          <div class="panel-pixel p-6">
            <p
              class="text-[color:var(--color-muted)] text-sm"
              style="font-family: var(--font-body);"
            >
              No devlog entries yet for this roadmap item.
            </p>
          </div>
        ) : (
          <ol class="space-y-6">
            {renderedEntries.map(({ entry, Content }) => {
              const anchor = entry.id.split("/").pop() ?? entry.id;
              const date = entry.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              });
              return (
                <li id={anchor} class="panel-pixel p-6 scroll-mt-20">
                  <time
                    class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-muted)]"
                    style="font-family: var(--font-display);"
                  >
                    {date}
                  </time>
                  <h3
                    class="mt-2 font-bold text-lg sm:text-xl uppercase tracking-wide text-[color:var(--color-gold)]"
                    style="font-family: var(--font-display);"
                  >
                    {entry.data.title}
                  </h3>
                  {entry.data.summary && (
                    <p
                      class="mt-2 text-[color:var(--color-sky-light)] text-sm"
                      style="font-family: var(--font-body);"
                    >
                      {entry.data.summary}
                    </p>
                  )}
                  <div
                    class="mt-4 text-sm text-[color:var(--color-fg)]/90 leading-relaxed space-y-3"
                    style="font-family: var(--font-body);"
                  >
                    <Content />
                  </div>
                </li>
              );
            })}
          </ol>
        )
      }
    </div>
  </section>
</Layout>
